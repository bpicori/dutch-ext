{
  "manifest_version": 3,
  "name": "WachtNederlands",
  "version": "0.1.0",
  "description": "Learn Dutch one new tab at a time",
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "permissions": ["storage"],
  "optional_permissions": ["audioCapture"],
  "web_accessible_resources": [
    {
      "resources": ["challenges/*.json", "images/*"],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
