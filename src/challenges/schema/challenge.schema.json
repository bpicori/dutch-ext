{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TabTaalChallengeDeck",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["id", "type", "prompt", "correctAnswer"],
    "additionalProperties": false,
    "properties": {
      "id": { "type": "string", "minLength": 1 },
      "type": { "type": "string", "minLength": 1 },
      "prompt": { "type": "string", "minLength": 1 },
      "correctAnswer": { "type": "string", "minLength": 1 },
      "level": { "enum": ["a1", "a2", "b1"] },
      "topic": { "type": "string" },
      "tags": { "type": "array", "items": { "type": "string" } },
      "choices": { "type": "array", "items": { "type": "string" } },
      "acceptableAnswers": { "type": "array", "items": { "type": "string" } },
      "context": { "type": "string" },
      "promptAudio": { "type": "string" },
      "audioWords": { "type": "array", "items": { "type": "string" } },
      "orderItems": { "type": "array", "items": { "type": "string" } },
      "matchLeft": { "type": "array", "items": { "type": "string" } },
      "matchRight": { "type": "array", "items": { "type": "string" } }
    }
  }
}
